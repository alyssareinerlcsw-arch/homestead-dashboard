# Neon Postgres — get from console.neon.tech after creating a project
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Gemini — get from aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# Google OAuth — get from console.cloud.google.com
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Oura — get from cloud.ouraring.com/personal-access-tokens
OURA_ACCESS_TOKEN=""

# Set to your Railway public URL after first deploy
NEXT_PUBLIC_BASE_URL=""
